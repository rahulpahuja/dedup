<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- EncryptedSharedPreferences key store — contains DB encryption key -->
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <!-- DataStore preferences (settings, currency, theme, etc.) -->
        <exclude domain="file" path="datastore/"/>
        <!-- Room database and its WAL/SHM journal files -->
        <exclude domain="database" path="dedup_database"/>
        <exclude domain="database" path="dedup_database-shm"/>
        <exclude domain="database" path="dedup_database-wal"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="database" path="dedup_database"/>
        <exclude domain="database" path="dedup_database-shm"/>
        <exclude domain="database" path="dedup_database-wal"/>
    </device-transfer>
</data-extraction-rules>
