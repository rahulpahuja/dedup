<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Internet / Network ── -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── Media — Images (API 33+ granular; legacy below API 33) ── -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:ignore="PhotoAndVideoPolicy" />
    <!-- Partial photo/video picker (API 34+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- ── Media — Video ── -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:ignore="PhotoAndVideoPolicy" />

    <!-- ── Media — Audio (API 33+) ── -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- ── Storage — legacy read (API ≤ 32) ── -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- ── Storage — legacy write (API ≤ 28, needed for file deletion) ── -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- ── Notifications (API 33+ runtime permission) ── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Contacts ── -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!-- ── Location (coarse — used for sunrise/sunset auto-theme; no active request) ── -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- ── All Files Access (API 30+) ── -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".core.app.DeDupApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DeDup"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:extractNativeLibs="false"
        android:enableOnBackInvokedCallback="true">

        <!-- Facebook Metadata using Manifest Placeholders -->
        <meta-data android:name="com.facebook.sdk.ApplicationId" android:value="${facebook_app_id}" />
        <meta-data android:name="com.facebook.sdk.ClientToken" android:value="${facebook_client_token}"/>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="@string/app_name"
            android:theme="@style/Theme.DeDup">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Android 17 App Bubble Activity -->
        <activity
            android:name=".core.bubble.BubbleActivity"
            android:label="DeDup Scanner"
            android:theme="@style/Theme.DeDup"
            android:allowEmbedded="true"
            android:resizeableActivity="true"
            android:exported="false">
        </activity>

        <activity
            android:name=".DemotestActivity"
            android:exported="false"
            android:label="Notification Demo"
            android:theme="@style/Theme.DeDup" />

        <service
            android:name=".core.firebase.notifications.FirebaseMessageService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".core.widget.StorageWidgetReceiver"
            android:exported="true"
            android:label="DeDup Storage Widget"
            android:permission="android.permission.BIND_REMOTEVIEWS">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/storage_widget_info" />
        </receiver>

        <!-- Receiver for Storage Level Monitoring -->
        <!-- Protected by checking the action and potentially the sender in code -->
        <receiver
            android:name=".core.notifications.StorageLevelReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.DEVICE_STORAGE_LOW" />
                <action android:name="android.intent.action.DEVICE_STORAGE_OK" />
            </intent-filter>
        </receiver>

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="androidx.appcompat.app.AppLocalesMetadataHolderService" />
            </intent-filter>
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <!-- Android 17 Handoff Receiver -->
        <receiver
            android:name=".core.handoff.HandoffReceiver"
            android:exported="true"
            android:permission="android.permission.ACCEPT_HANDOFF">
            <intent-filter>
                <action android:name="android.intent.action.HANDOFF_RECEIVED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
